# Cubo com normais para iluminacao Phong (M4)

o Cube

# Vertices (8 cantos)
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

# Coordenadas de textura
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# Normais (uma para cada face do cubo)
vn  0.0  0.0 -1.0  # Tras
vn  0.0  0.0  1.0  # Frente
vn  1.0  0.0  0.0  # Direita
vn -1.0  0.0  0.0  # Esquerda
vn  0.0  1.0  0.0  # Cima
vn  0.0 -1.0  0.0  # Baixo

# Material
mtllib cube.mtl
usemtl PhongMaterial

# Faces com indices v/vt/vn
# Frente  (z = +0.5)
f 5/1/2 6/2/2 7/3/2 8/4/2

# Tras    (z = -0.5)
f 2/1/1 1/2/1 4/3/1 3/4/1

# Direita (x = +0.5)
f 6/1/3 2/2/3 3/3/3 7/4/3

# Esquerda (x = -0.5)
f 1/1/4 5/2/4 8/3/4 4/4/4

# Cima    (y = +0.5)
f 8/1/5 7/2/5 3/3/5 4/4/5

# Baixo   (y = -0.5)
f 1/1/6 2/2/6 6/3/6 5/4/6
